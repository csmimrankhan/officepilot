# Local environment template (root, optional)
# The backend prefers backend/.env but will also read this file.

OFFICEPILOT_ENV=development
OFFICEPILOT_DB_URL=sqlite:///./officepilot.db
OFFICEPILOT_STORAGE_ROOT=./storage
OFFICEPILOT_OCR_ENABLED=true
OFFICEPILOT_TESSERACT_CMD=
OFFICEPILOT_MAX_UPLOAD_MB=20
OFFICEPILOT_CONFIDENCE_THRESHOLD=0.6
OFFICEPILOT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Phase 13: QuickBooks/Xero accounting sync
# ACCOUNTING_SYNC_ENABLED=false
# ACCOUNTING_REQUIRE_APPROVAL=true
# ACCOUNTING_DRAFT_ONLY=true
# ACCOUNTING_BLOCK_DUPLICATES=true
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=http://127.0.0.1:8000/api/accounting/quickbooks/callback
# QUICKBOOKS_ENV=mock
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=http://127.0.0.1:8000/api/accounting/xero/callback
# XERO_ENV=mock

# Phase 12: Browser automation (Playwright)
# BROWSER_AUTOMATION_ENABLED=false
# BROWSER_HEADLESS=false
# BROWSER_SCREENSHOTS_ENABLED=true
# BROWSER_ALLOWED_DOMAINS=localhost,127.0.0.1,docs.google.com,sheets.google.com,sandbox.qbo.intuit.com,login.xero.com,go.xero.com
# BROWSER_BLOCKED_DOMAINS=chase.com,bankofamerica.com,paypal.com,coinbase.com,1password.com,irs.gov
# BROWSER_REQUIRE_APPROVAL_FOR_WRITE=true
# BROWSER_REQUIRE_APPROVAL_FOR_SUBMIT=true
# BROWSER_MAX_RUNS=200
# BROWSER_PLAYWRIGHT_BROWSERS_PATH=

# Phase 17: Authentication (JWT defaults auto-generated if empty)
# JWT_SECRET=
# ALLOW_OPEN_REGISTRATION=false
# ALLOW_FIRST_OWNER_BOOTSTRAP=true
