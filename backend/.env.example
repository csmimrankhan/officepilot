# OfficePilot AI — backend environment variables (all optional, defaults shown)
# Copy this file to `.env` at the repo root to override defaults.

OFFICEPILOT_ENV=development
OFFICEPILOT_DB_URL=sqlite:///./officepilot.db
OFFICEPILOT_STORAGE_ROOT=./storage

# OCR — install Tesseract separately and point to its binary if it isn't on PATH.
OFFICEPILOT_OCR_ENABLED=true
OFFICEPILOT_TESSERACT_CMD=

# Limits
OFFICEPILOT_MAX_UPLOAD_MB=20
OFFICEPILOT_CONFIDENCE_THRESHOLD=0.6

# CORS (comma-separated)
OFFICEPILOT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Phase 2: Gmail integration ----
# Create a Google Cloud OAuth client (Web application) and paste the values here.
# Required scopes are only gmail.readonly — we never request write/modify scopes.
OFFICEPILOT_GMAIL_CLIENT_ID=
OFFICEPILOT_GMAIL_CLIENT_SECRET=
OFFICEPILOT_GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/gmail/callback

# 44-char url-safe base64 Fernet key. Leave blank to auto-generate one in
# OFFICEPILOT_GMAIL_STATE_DIR on first run (NOT recommended for production).
OFFICEPILOT_GMAIL_TOKEN_KEY=

OFFICEPILOT_GMAIL_STATE_DIR=./storage/gmail

# Sync tuning
OFFICEPILOT_GMAIL_MIN_SCORE=0.4
OFFICEPILOT_GMAIL_MAX_RESULTS=50
OFFICEPILOT_GMAIL_SEARCH_DAYS=30

# If false, the real Gmail API is never contacted and a built-in fake client
# is used (useful for local dev and CI without a Google account).
OFFICEPILOT_GMAIL_ALLOW_REAL=true
