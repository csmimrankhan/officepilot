# Tauri Updater signing key configuration
# =========================================
# Copy this file to .env.updater and fill in your values.
# NEVER commit the actual private key to version control.

# Path to the private key PEM file (alternative to setting the key inline)
TAURI_SIGNING_PRIVATE_KEY_PATH=.updater-private-key.pem

# The private key itself (base64-encoded, alternative to path)
# TAURI_SIGNING_PRIVATE_KEY=

# Password used when generating the private key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=officepilot-updater-key

# Updater endpoint URLs
# Local development:
UPDATER_ENDPOINT=http://localhost:8765/api/app/updater/windows/stable
# Production:
# UPDATER_ENDPOINT=https://officepilot.ai/api/app/updater/windows/stable
